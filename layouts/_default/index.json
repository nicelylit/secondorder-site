{{- $.Scratch.Add "index" slice -}}
{{- range where .Site.RegularPages "Type" "in" (slice "posts" "engineering" "writing") -}}
  {{- $.Scratch.Add "index" (dict 
    "title" .Title 
    "content" (.Plain | truncate 500)
    "permalink" .Permalink
    "date" .Date
    "categories" .Params.categories
    "tags" .Params.tags
  ) -}}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}
